{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "⚙️ 启动前端服务",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "severity": "info",
        "pattern": { "regexp": ".*" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE v",
          "endsPattern": "ready in"
        }
      },
      "detail": "启动前端开发服务器（端口 5173）"
    },
    {
      "label": "⚙️ 一键打包",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "${workspaceFolder}/build/build.bat"],
      "group": { "kind": "build", "isDefault": true },
      "detail": "安装依赖 → 构建前端 → 打包 dida.exe"
    }
  ]
}
