{
  "version": "0.2.0",
  "configurations": [
    // ══════════════════════════════════════════
    //  Go 后端调试
    // ══════════════════════════════════════════
    {
      "name": "🔧 Go 后端 (开发模式 + WebView2)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend",
      "buildFlags": [
        "-ldflags=-X 'main.devMode=true'",
        "-buildvcs=false"
      ],
      "env": {},
      "args": [],
      "output": "${workspaceFolder}/go_debug.exe",
      "cwd": "${workspaceFolder}/backend",
      "showLog": true,
      "trace": "verbose",
      "preLaunchTask": "dev: frontend (pnpm dev)",
      "detail": "调试 Go 后端，devMode=true → WebView2 指向 localhost:5173，API 在 18520"
    }
  ],
  // ─── 复合配置：一键启动完整开发环境 ───
  "compounds": [
    {
      "name": "🚀 完整调试 (Go 后端 + 前端)",
      "configurations": [
        "🔧 Go 后端 (开发模式 + WebView2)",
        "🌐 前端 (Vite + Edge)"
      ],
      "preLaunchTask": "dev: frontend (pnpm dev)",
      "stopAll": true,
      "detail": "同时启动：Go 后端调试 + Vite + Edge 浏览器，全面断点调试"
    }
  ]
}
