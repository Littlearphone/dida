{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🐛 后端接口",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend",
      "buildFlags": [
        "-ldflags=-X 'main.devMode=true'",
        "-buildvcs=false"
      ],
      "env": {},
      "args": [],
      "output": "${workspaceFolder}/go_debug.exe",
      "cwd": "${workspaceFolder}/backend",
      "showLog": true,
      "trace": "verbose",
      "detail": "Go 后端调试，可断点调试 API 接口"
    },
    {
      "name": "🐛 前端页面",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/src/*"
      },
      "preLaunchTask": "⚙️ 启动前端服务",
      "detail": "浏览器打开前端页面，可断点调试 Vue 代码"
    }
  ]
}
